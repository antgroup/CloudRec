# Local development fallback only. Prefer `cloudrec-lite credentials store` for
# normal use so AK/SK values are kept out of plaintext files.
ALIBABA_CLOUD_ACCESS_KEY_ID=replace-with-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=replace-with-access-key-secret
ALIBABA_CLOUD_REGION=cn-hangzhou
# Optional for temporary credentials:
# ALIBABA_CLOUD_SECURITY_TOKEN=replace-with-security-token
